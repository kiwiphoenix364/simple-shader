/lkupx16: Buffer&#13;" line4="    //Shader pack&#13;" line5="    public refreshShaderLayer: boolean&#13;" line6="    //Decompiled shader pack&#13;" line7="    protected decompShader: Buffer&#13;" line8="    //Shader augment image&#13;" line9="    public shaderLayer: Image&#13;" line10="    //zValue&#13;" line11="    protected zValue: number&#13;" line12="    //Renderable for shader&#13;" line13="    private shader: scene.Renderable&#13;" line14="    protected updater: control.FrameCallback&#13;" line15="    constructor(currentPack: SS_ShaderPack, refreshShaderLayer = true, zValue = 0) {&#13;" line16="        /*&#13;" line17="        //build lookup table&#13;" line18="        this.lkupx16 = Buffer.create(16)&#13;" line19="        for (let i = 0; i &lt; 16; i++) {&#13;" line20="            this.lkupx16[i] = (i * 16)&#13;" line21="        }&#13;" line22="        */&#13;" line23="        this.refreshShaderLayer = refreshShaderLayer&#13;" line24="        this.zValue = zValue&#13;" line25="        //Unpack SS_Shaderpack&#13;" line26="        this.decompShader = currentPack.unpack()&#13;" line27="        //create buffer image&#13;" line28="        this.shaderLayer = image.create(scene.screenWidth(), scene.screenHeight())&#13;" line29="        this.runShader()&#13;" line30="        this.updateShaderLayer()&#13;" line31="    }&#13;" line32="    protected runShader() {&#13;" line33="        this.shader = scene.createRenderable(this.zValue, (screenImg: Image, camera: scene.Camera) =&gt; {&#13;" line34="            this.shadeImg(screenImg)&#13;" line35="        })&#13;" line36="    }&#13;" line37="    protected shadeImg(img: Image) {&#13;" line38="        let shaderBuf = Buffer.create(Math.imul(img.width, img.height))&#13;" line39="        let renderBuf = Buffer.create(Math.imul(img.width, img.height))&#13;" line40="        let decompShader = Buffer.create(0).concat(this.decompShader)&#13;" line41="        img.getRows(0, renderBuf)&#13;" line42="        this.shaderLayer.getRows