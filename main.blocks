    this.currentRad += Math.randomRange(0 - this.smoothness, this.smoothness)&#13;" line79="        //this.currentRad = Math.constrain(this.currentRad, this.radius + this.flux, this.radius - this.flux)&#13;" line80="        if (this.currentRad &gt; this.radius + this.flux || this.currentRad &lt; this.radius - this.flux) {&#13;" line81="            this.currentRad -= this.currentRad - (this.radius + this.flux)&#13;" line82="        }&#13;" line83="    }&#13;" line84="    public destroy() {&#13;" line85="        game.currentScene().eventContext.unregisterFrameHandler(this.updater)&#13;" line86="        this.shader = this.sprite = this.tint = this.radius = this.currentRad = this.flux = this.smoothness = this.xOffset = this.yOffset = this.updater = this.lite = this.l2 = this.mapLayer = null&#13;" line87="    }&#13;" line88="}" numlines="89"></mutation><next><block type="typescript_statement" id="lPOcz*ua}XO]R-X]-%Y@"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="class TileShader {&#13;" line1="    public shader: Shader | LiteShader&#13;" line2="    public mapLayer: Image&#13;" line3="    public image: Image&#13;" line4="    protected x: number&#13;" line5="    protected y: number&#13;" line6="    protected left: number&#13;" line7="    protected top: number&#13;" line8="    protected right: number&#13;" line9="    protected bottom: number&#13;" line10="    protected updater: control.FrameCallback&#13;" line11="    protected lite = false&#13;" line12="    protected l2 = false&#13;" line13="    constructor(shader: Shader | LiteShader, image: Image, x: number, y: number, liteShader = false, layer2 = false) {&#13;" line14="        this.image = image&#13;" line15="        this.x = x&#13;" line16="        this.y = y&#13;" line17="        if (this.lite = liteShader) {&#13;" line18="            this.shader = shader&#13;" line19="            if (this.l2 = layer2) {&#13;" line20="                this.mapLayer = (shader as LiteShaderX2).mapLayer2&#13;" line21="            